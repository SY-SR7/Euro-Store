const fs = require('fs');
const path = require('path');

const root = process.cwd();
const backupDir = path.join(root, process.argv[2]);

const skipDirs = new Set([
  '.git',
  'node_modules',
  '.next',
  '.turbo',
  'dist',
  'build',
  'coverage',
  '.vercel'
]);

const skipPrefix = /^_backup_/;

const allowedExt = new Set([
  '.ts', '.tsx', '.js', '.jsx', '.mjs', '.cjs',
  '.json', '.jsonc', '.md', '.mdx',
  '.css', '.scss',
  '.html',
  '.sql',
  '.env', ''
]);

const cp1252 = {
  '€': 0x80, '‚': 0x82, 'ƒ': 0x83, '„': 0x84, '…': 0x85,
  '†': 0x86, '‡': 0x87, 'ˆ': 0x88, '‰': 0x89, 'Š': 0x8A,
  '‹': 0x8B, 'Œ': 0x8C, 'Ž': 0x8E, '‘': 0x91, '’': 0x92,
  '“': 0x93, '”': 0x94, '•': 0x95, '–': 0x96, '—': 0x97,
  '˜': 0x98, '™': 0x99, 'š': 0x9A, '›': 0x9B, 'œ': 0x9C,
  'ž': 0x9E, 'Ÿ': 0x9F
};

function encodeCp1252(s) {
  const bytes = [];

  for (const ch of s) {
    const code = ch.codePointAt(0);

    if (code <= 0xff) {
      bytes.push(code);
      continue;
    }

    if (Object.prototype.hasOwnProperty.call(cp1252, ch)) {
      bytes.push(cp1252[ch]);
      continue;
    }

    return null;
  }

  return Buffer.from(bytes);
}

function hasArabic(s) {
  return /[\u0600-\u06FF]/.test(s);
}

function looksBroken(s) {
  return /[ØÙÛÐÑÃÂ]/.test(s);
}

function decodeOnceToken(token) {
  if (!looksBroken(token)) return token;

  const buf = encodeCp1252(token);
  if (!buf) return token;

  const decoded = buf.toString('utf8');

  if (!hasArabic(decoded)) return token;
  if (decoded.includes('�')) return token;

  return decoded;
}

const broadTokenRegex =
  /[\u00A0-\u00FF\u0152\u0153\u0160\u0161\u0178\u017D\u017E\u0192\u02C6\u02DC\u2013\u2014\u2018\u2019\u201A\u201C\u201D\u201E\u2020\u2021\u2022\u2026\u2030\u2039\u203A\u20AC\u2122]{2,}/g;

function genericFix(text) {
  let out = text;

  for (let i = 0; i < 6; i++) {
    const next = out.replace(broadTokenRegex, decodeOnceToken);
    if (next === out) break;
    out = next;
  }

  return out;
}

function targetedFix(text) {
  const replacements = [
    ['Ø§Ù„ØªØµÙ†ÙŠÙ�', 'التصنيف'],
    ['Ø§Ù„ØªØµÙ†ÙŠÙف', 'التصنيف'],
    ['Ø§Ù„ØªØµÙ†ÙŠÙ', 'التصنيف'],
    ['ØªØ³ÙˆÙ‚', 'تسوق'],
    ['Ø­Ø³Ø¨', 'حسب'],
    ['Ø¢Ø®Ø±', 'آخر'],
    ['Ø§Ù„ÙƒÙˆÙ„ÙƒØ´Ù†', 'الكولكشن'],
    ['Ø§Ù„Ù…ØªØ§Ø­Ø©', 'المتاحة'],
    ['Ù‚Ø·Ø¹Ø© Ù…ØªØ§Ø­Ø©', 'قطعة متاحة'],
    ['Ù„.Ø³', 'ل.س'],
    ['Ù„.س', 'ل.س']
  ];

  let out = text;

  for (const [bad, good] of replacements) {
    out = out.split(bad).join(good);
  }

  return out;
}

function fixText(text) {
  return targetedFix(genericFix(text));
}

function backupFile(file) {
  const rel = path.relative(root, file);
  const safe = rel.replace(/[\\/:*?"<>|]/g, '_');
  const out = path.join(backupDir, safe + '.bak');

  fs.mkdirSync(path.dirname(out), { recursive: true });
  fs.copyFileSync(file, out);
}

function walk(dir, files = []) {
  if (!fs.existsSync(dir)) return files;

  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
    if (skipDirs.has(entry.name)) continue;
    if (skipPrefix.test(entry.name)) continue;

    const full = path.join(dir, entry.name);

    if (entry.isDirectory()) {
      walk(full, files);
      continue;
    }

    if (!entry.isFile()) continue;

    const ext = path.extname(entry.name);
    if (!allowedExt.has(ext)) continue;

    files.push(full);
  }

  return files;
}

const files = walk(root);
let changed = 0;

for (const file of files) {
  let oldText;

  try {
    oldText = fs.readFileSync(file, 'utf8');
  } catch {
    continue;
  }

  if (!looksBroken(oldText)) continue;

  const newText = fixText(oldText);

  if (newText !== oldText) {
    backupFile(file);
    fs.writeFileSync(file, newText, 'utf8');
    changed++;
    console.log('fixed:', path.relative(root, file));
  }
}

console.log('');
console.log(`changed files: ${changed}`);
console.log(`backup: ${backupDir}`);

console.log('');
console.log('Remaining suspicious files:');

let remaining = 0;

for (const file of files) {
  let text;

  try {
    text = fs.readFileSync(file, 'utf8');
  } catch {
    continue;
  }

  if (looksBroken(text)) {
    remaining++;
    console.log('-', path.relative(root, file));
  }
}

if (remaining === 0) {
  console.log('none');
}
