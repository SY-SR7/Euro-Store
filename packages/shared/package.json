{
    "name":  "@eurostore/shared",
    "version":  "1.0.0",
    "private":  true,
    "dependencies":  {
                         "@upstash/ratelimit":  "^1.1.3",
                         "@upstash/redis":  "^1.30.0",
                         "jsonwebtoken":  "^9.0.2",
                         "next-intl":  "^4.13.0",
                         "otplib":  "^12.0.1",
                         "zod":  "^3.23.8"
                     },
    "devDependencies":  {
                            "@eurostore/config":  "workspace:*",
                            "@types/jsonwebtoken":  "^9.0.6",
                            "typescript":  "^5.4.5"
                        },
    "main":  "./src/index.ts",
    "types":  "./src/index.ts",
    "exports":  {
                    "./email/orderConfirmation":  {
                                                      "types":  "./src/email/orderConfirmation.ts",
                                                      "default":  "./src/email/orderConfirmation.ts"
                                                  },
                    ".":  {
                              "types":  "./src/index.ts",
                              "default":  "./src/index.ts"
                          },
                    "./src/messages":  {
                                           "types":  "./src/messages/index.ts",
                                           "default":  "./src/messages/index.ts"
                                       },
                    "./src/messages/*":  {
                                             "default":  "./src/messages/*"
                                         },
                    "./messages":  {
                                       "types":  "./src/messages/index.ts",
                                       "default":  "./src/messages/index.ts"
                                   },
                    "./messages/*":  {
                                         "default":  "./src/messages/*"
                                     }
                }
}
