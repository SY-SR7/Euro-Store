# ============================================
# EuroStore Environment Variables
# Copy to .env.local in each app — NEVER commit .env.local
# ============================================

# Provider Selection — switch these when migrating hosting/data/storage providers
EUROSTORE_DEPLOYMENT_PROVIDER=      # vercel | hostinger | cloudflare_pages | node_server | other
EUROSTORE_DATABASE_PROVIDER=        # supabase | postgres | hostinger_postgres
EUROSTORE_AUTH_PROVIDER=            # supabase | authjs | custom_jwt
EUROSTORE_STORAGE_PROVIDER=         # supabase | s3 | cloudflare_r2 | hostinger | local_private
EUROSTORE_EMAIL_PROVIDER=           # resend | smtp | hostinger_email | none
EUROSTORE_PAYMENT_PROVIDER=         # sham_cash | cash_on_delivery_only | none

# Public provider hints — safe to expose; needed by browser/mobile public clients
NEXT_PUBLIC_EUROSTORE_DEPLOYMENT_PROVIDER=
NEXT_PUBLIC_EUROSTORE_DATABASE_PROVIDER=
EXPO_PUBLIC_EUROSTORE_DEPLOYMENT_PROVIDER=
EXPO_PUBLIC_EUROSTORE_DATABASE_PROVIDER=

# Supabase — required only when EUROSTORE_DATABASE_PROVIDER or EUROSTORE_AUTH_PROVIDER or EUROSTORE_STORAGE_PROVIDER uses supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY — never prefix with NEXT_PUBLIC_
SUPABASE_JWT_SECRET=                # From Supabase dashboard

# Portable PostgreSQL — required when EUROSTORE_DATABASE_PROVIDER is postgres or hostinger_postgres
DATABASE_URL=
DATABASE_DIRECT_URL=

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Security
EXCHANGE_QR_SECRET=                 # 64-char random string for HS256 JWT signing — openssl rand -hex 32
EUROSTORE_AUTH_COOKIE_SECRET=       # Random 64-char secret for signed httpOnly auth step cookies
EUROSTORE_AUTH_TOTP_ISSUER=         # TOTP issuer name shown in authenticator apps

# Email
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Push Notifications
EXPO_ACCESS_TOKEN=
FCM_SERVICE_ACCOUNT=                # Stringified Firebase service account JSON

# Payment — Sham Cash [TBD]
SHAM_CASH_API_KEY=
SHAM_CASH_API_URL=
SHAM_CASH_WEBHOOK_SECRET=

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# S3-Compatible Storage — Cloudflare R2, Hostinger object storage, AWS S3, etc.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# App Config
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_ADMIN_URL=
NEXT_PUBLIC_HELPER_URL=
NEXT_PUBLIC_PARTNER_URL=
EXPO_PUBLIC_APP_URL=
EXPO_PUBLIC_ADMIN_URL=
EXPO_PUBLIC_HELPER_URL=
EXPO_PUBLIC_PARTNER_URL=

# Node Environment
NODE_ENV=development
